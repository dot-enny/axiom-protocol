# Copy this file to .env.local and fill in real values. .env.local is
# gitignored — never commit real secrets.

# The deployed AxiomContract contract ID on Stellar Soroban Testnet.
NEXT_PUBLIC_CONTRACT_ID=

# Secret key (starts with "S") of the Stellar account the headless
# /api/v1/anchor route signs and submits transactions with. The
# contract itself has no admin gating — anchor_proof only requires the
# `issuer` argument's own auth — so this can be any funded Testnet
# account; it just needs to exist and hold enough XLM to pay fees.
# Fund a fresh one via https://friendbot.stellar.org if needed.
SERVER_SECRET_KEY=
